// 租户表
kh_plat_tnt[1] <
    cd: 'TNT' + [1, 100],
    nm: '云租户',
    stdt: lmt,
    eddt: null,
    lmt: lmt
>

// 组织机构表
kh_plat_org[1] <
    cd: 'ORG' + [1, 100],
    pcd: &kh_plat_org(cd),
    tntcd: &kh_plat_tnt(cd),
    nm: organization#name,
    addr: '未设置',
    zipcd: '400000',
    addvcd: &kh_plat_addv(cd),
    ldr: &kh_plat_emp(cd),
    lmt: lmt
>

// 用户表
kh_plat_usr[5] <
    cd: 'USR' + [1, 100],
    empcd: &kh_plat_emp(cd),
    accnm: 'test' + [1,5],
    pwd: '202CB962AC59075B964B07152D234B70',
    tntcd: &kh_plat_tnt(cd),
    sts: 'A',
    lmt: lmt
>

// 职员表
kh_plat_emp[5] <
    cd: 'EMP' + [1, 100],
    nm: person#name,
    gdr: 'M',
    phn: '68459976',
    eml: 'helloworld@qq.com',
    mbl: '13987483746',
    pos: '普通员工',
    ord: 1,
    hdt: lmt,
    fdt: null,
    sts: 'A',
    lmt: lmt
>

// 职员组织机构表
kh_plat_emporg[5] <
    empcd: &kh_plat_emp(cd),
    orgcd: &kh_plat_org(cd),
    pos: '普通员工',
    lmt: lmt
>

// 角色表
kh_plat_rle[1] <
    cd: 'RLE' + [1, 100],
    tntcd: &kh_plat_tnt(cd),
    nm: '普通员工',
    tp: 'U'
>

// 用户角色
kh_plat_usrrle[5] <
    usrcd: &kh_plat_usr(cd),
    rlecd: &kh_plat_rle(cd),
    lmt: lmt
>

// 角色、机构应用功能表
kh_plat_grpapp[5] <
    tntappcd: &kh_plat_tntapp(cd),
    grpcd: 'GRP' + [1,3],
    tp: [R, M],
    lmt: lmt
>

// 应用表
kh_plat_app[5] <
    cd: 'APP' + [1, 100],
    nm: '测试应用' + [1,5],
    icn : null
>

// 应用功能表
kh_plat_appfn[5] <
    cd: 'APPFN' + [1, 100],
    pcd: &kh_plat_appfn(cd),
    appcd: &kh_plat_app(cd),
    nm: '测试应用' + [1,5],
    icn: null,
    uri: null,
    ord: 1,
    tp: 'P'
>

// 租户应用表
kh_plat_tntapp[5] <
    cd: 'TNTAPP' + [1, 100],
    tntcd: &kh_plat_tnt(cd),
    appcd: &kh_plat_app(cd),
    appnm: '测试应用' + [1,5],
    appicn: null,
    svr: '192.168.0.1',
    port: '8088',
    ctxpth: 'test'
>

// 租户应用功能表
kh_plat_tntappfn[5] <
    cd: 'TNTAPPFN' + [1, 100],
    tntcd: &kh_plat_tnt(cd),
    appcd: &kh_plat_app(cd),
    appnm: '测试应用' + [1,5],
    fncd: &kh_plat_appfn(cd),
    fnpcd: &kh_plat_appfn(cd),
    fnnm: '测试应用' + [1,5],
    fnuri: null,
    fnicn: null,
    fnord: 1
>

// 用户应用表
kh_plat_usrapp[5] <
    tntappcd: &kh_plat_tntapp(cd),
    usrcd: &kh_plat_usr(cd),
    lmt: lmt
>

// 行政区划表
kh_plat_addv[10] <
    cd: 'ADDV' + [1, 100],
    pcd: null,
    fnm: district#code
>


